{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OTTO",
  "version": "0.1.0",
  "identifier": "com.research.otto",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bash src-tauri/build-audiotap.sh && npm run dev",
    "beforeBuildCommand": "bash src-tauri/build-audiotap.sh && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OTTO",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/backend/": "backend/",
      "audiotap/.build/release/otto-audiotap": "audiotap/otto-audiotap"
    },
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
