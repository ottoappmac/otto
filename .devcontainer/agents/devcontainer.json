{
	"name": "MLX Agents",
	"dockerComposeFile": "compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"customizations": {
		"vscode": {
			"extensions": [
				"mhutchie.git-graph",
				"ms-toolsai.jupyter",
				"ms-toolsai.jupyter-keymap",
				"ms-toolsai.jupyter-renderers",
				"ms-python.python",
				"ms-python.flake8",
				"ms-azuretools.vscode-docker",
				"ms-python.debugpy"
			]
		}
	},
	"remoteEnv": {
		"COHERE_API_KEY": "${localEnv:COHERE_API_KEY}",
		"WS_DIR": "${containerWorkspaceFolder}"
	},
	"postCreateCommand": "pip install -e .",
	"postAttachCommand": "python .devcontainer/agents/post_create_tests.py && PYTHONPATH=src pytest tests/ -v"
}
